cargo:rerun-if-changed=build.rs
cargo:rerun-if-env-changed=CUDARC_CUDA_VERSION
cargo:rerun-if-env-changed=CUDA_HOME
cargo:rerun-if-env-changed=CUDA_PATH
cargo:rerun-if-env-changed=CUDA_ROOT
cargo:rerun-if-env-changed=CUDA_TOOLKIT_ROOT_DIR
cargo:rerun-if-env-changed=CUDNN_LIB
cargo:rustc-cfg=feature="cuda-13010"
cargo:rustc-env=CUDA_MAJOR_VERSION=13
cargo:rustc-env=CUDA_MINOR_VERSION=1
cargo:rustc-link-search=native=/usr/lib
cargo:rustc-link-search=native=/usr/lib64
cargo:rustc-link-search=native=/usr/local/cuda/lib64
cargo:rustc-link-search=native=/usr/local/cuda/lib64/stubs
cargo:rustc-link-search=native=/usr/local/cuda/targets/x86_64-linux
cargo:rustc-link-search=native=/usr/local/cuda/targets/x86_64-linux/lib
cargo:rustc-link-search=native=/usr/local/cuda/targets/x86_64-linux/lib/stubs
cargo:rustc-link-lib=dylib=cuda
cargo:rustc-link-lib=dylib=nvrtc
cargo:rustc-link-lib=dylib=curand
cargo:rustc-link-lib=dylib=cublas
cargo:rustc-link-lib=dylib=cublasLt
